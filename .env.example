# Copy to .env (which is gitignored) or, better, export in your shell profile.
# loci reads its key from the environment at runtime and never writes it anywhere.
#
# Preferred: loci's OWN variable, isolated from the shared ANTHROPIC_API_KEY that
# other tools read (and sometimes clobber). loci checks LOCI_ANTHROPIC_KEY first,
# then falls back to ANTHROPIC_API_KEY.
LOCI_ANTHROPIC_KEY=
